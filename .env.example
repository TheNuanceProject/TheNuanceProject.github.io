# Cloudflare Web Analytics beacon token.
#
# Set this in `.env.local` for local development, or as a GitHub
# Actions secret named `VITE_CLOUDFLARE_ANALYTICS_TOKEN` for the
# production build. When the variable is unset, the beacon script
# is simply not emitted — local builds stay clean.
#
# The token itself is not secret (it ships publicly in every
# visitor's HTML), but keeping it out of the repo means it can be
# rotated without touching the codebase.
VITE_CLOUDFLARE_ANALYTICS_TOKEN=
