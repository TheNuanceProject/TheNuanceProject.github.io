# EditorConfig — https://editorconfig.org
#
# Universal editor settings so every contributor (and every editor)
# produces consistently formatted files. Most modern editors read this
# file automatically.

root = true

# ─── Defaults ─────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ─── TypeScript / JavaScript / CSS / HTML ────────────────────────────
[*.{ts,tsx,js,jsx,mjs,cjs,css,html}]
indent_size = 2
max_line_length = 100

# ─── Markdown ─────────────────────────────────────────────────────────
[*.md]
indent_size = 2
trim_trailing_whitespace = false
max_line_length = 80

# ─── Config files ─────────────────────────────────────────────────────
[*.{yml,yaml,json,toml}]
indent_size = 2

# ─── package.json — npm convention ───────────────────────────────────
[package.json]
indent_size = 2
